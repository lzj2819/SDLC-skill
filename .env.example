# DevForge Skill Chain — Recommended Environment Configuration
# =============================================================================
# This file is optional. DevForge skills work out of the box without any
# environment variables. However, configuring the sections below unlocks
# the full capability of certain stages (especially architecture validation
# with real-LLM sandbox simulation and cloud deployment).
#
# Usage:
#   1. Copy this file to .env and fill in your values
#   2. DevForge architecture-validation will read these when available
#   3. If absent, the skill degrades gracefully to mock-only validation
# =============================================================================

# ------------------------------------------------------------------------------
# LLM API Configuration (Optional — for real-LLM architecture validation)
# ------------------------------------------------------------------------------
# Used by: devforge-architecture-validation (Phase 4: LLM Sandbox Simulation)
# If not set, validation falls back to mock data + consistency checks.

# Provider: Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Provider: OpenAI (GPT)
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Provider: OpenRouter (unified access to multiple models)
OPENROUTER_API_KEY=sk-or-xxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model for validation (overrides skill default)
VALIDATION_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------------------------
# Database Configuration (Optional — for generated project scaffolding)
# ------------------------------------------------------------------------------
# Used by: devforge-project-scaffolding (generated .env.template for the target project)
# These are copied into the scaffolded project's .env.template, not used by the skill itself.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=devforge_app
DB_USER=app_user
DB_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Cache / Session store
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Cloud Platform Credentials (Optional — for ops-ready deployment)
# ------------------------------------------------------------------------------
# Used by: devforge-ops-ready (Terraform apply phase)
# Only needed when you actually deploy the generated infrastructure.

# AWS
AWS_ACCESS_KEY_ID=AKIAxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxx
AWS_REGION=us-east-1

# Azure
AZURE_SUBSCRIPTION_ID=xxxxx
AZURE_CLIENT_ID=xxxxx
AZURE_CLIENT_SECRET=xxxxx
AZURE_TENANT_ID=xxxxx

# GCP
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GOOGLE_PROJECT_ID=your-project-id

# ------------------------------------------------------------------------------
# Monitoring & Observability (Optional)
# ------------------------------------------------------------------------------
# Used by: devforge-ops-ready (Grafana datasource configuration)

GRAFANA_ADMIN_PASSWORD=changeme
PROMETHEUS_RETENTION=15d

# ------------------------------------------------------------------------------
# DevForge Skill Chain Internal (Rarely needed)
# ------------------------------------------------------------------------------
# FORCE_MOCK_VALIDATION=true   # Force architecture-validation to skip real-LLM checks
# DEBUG_SKILL_TRACE=true       # Enable verbose trace logging in all skills
